#!/usr/bin/env bash
# NotTheNet GUI launcher — thin wrapper executed AS ROOT by pkexec.
#
# Installed to /usr/local/bin/notthenet-gui by the installer.
# The .desktop file calls:  pkexec /usr/local/bin/notthenet-gui
#
# pkexec handles privilege escalation and, because the polkit action
# has allow_gui=true with exec.path pointing here, pkexec automatically
# forwards DISPLAY and XAUTHORITY into this process.

VENV_PYTHON="VENV_PYTHON_PLACEHOLDER"
SCRIPT="SCRIPT_PLACEHOLDER"

exec "$VENV_PYTHON" "$SCRIPT" "$@"
