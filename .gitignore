# NotTheNet
# ─────────────────────────────────────────────────────────────────────────────
# Do NOT commit private keys, captured emails or malware uploads.

# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
*.pyd

# Virtualenv
venv/
.venv/
env/

# Secrets / TLS keys and generated certs (NEVER commit)
certs/server.key
certs/server.crt
certs/ca.crt
certs/ca.key
certs/*.key
certs/*.crt
certs/*.p12
certs/*.pfx

# Captured data (may contain malware artifacts)
logs/
*.eml
*.bin

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# iptables save
/tmp/notthenet_iptables_save.rules

# Offline install wheelhouse (populated by prepare-usb.ps1)
wheelhouse/

# Generated single-file bundle (produced by make-bundle.ps1)
notthenet-bundle.sh

# mypy cache
.mypy_cache/

