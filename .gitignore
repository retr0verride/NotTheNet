# NotTheNet
# ─────────────────────────────────────────────────────────────────────────────
# Do NOT commit private keys, captured emails, secrets, or malware uploads.

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
*.pyd

# ── Virtualenv ────────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Twelve-Factor secrets (NEVER commit) ─────────────────────────────────────
.env
.env.*
!.env.example        # template is safe to commit
*.secret

# ── TLS keys and generated certs (NEVER commit) ──────────────────────────────
certs/server.key
certs/server.crt
certs/ca.crt
certs/ca.key
certs/*.key
certs/*.crt
certs/*.p12
certs/*.pfx

# ── Captured data (may contain malware artifacts) ────────────────────────────
logs/
*.eml
*.bin

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.lcov
.tox/
bandit-results.sarif

# ── iptables state snapshots (runtime, contain rule details) ─────────────────
logs/.iptables_save.rules
logs/.mangle_save.rules
logs/.filter_save.rules
/tmp/notthenet_iptables_save.rules

# ── Offline install wheelhouse (populated by prepare-usb.ps1) ────────────────
wheelhouse/

# ── Docker build artefacts ────────────────────────────────────────────────────
*.tar

# ── mypy cache ────────────────────────────────────────────────────────────────
.mypy_cache/

# Generated single-file bundle (produced by make-bundle.ps1)
notthenet-bundle.sh

# ── mypy cache
.mypy_cache/

# ── Documentation (kept locally, not published to repo)
docs/
.mypy_cache/

